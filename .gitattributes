# Text files are stored with LF in the repository; the working tree
# follows core.autocrlf / core.eol unless overridden below.
* text=auto

# Visual Studio project files and resource scripts check out with CRLF
# on every platform.
*.sln text eol=crlf
*.vcxproj text eol=crlf
*.filters text eol=crlf
*.rc text eol=crlf
*.rc2 text eol=crlf

# acknowledgements.txt is embedded verbatim as an RCDATA resource and shown
# in a multiline edit control, which needs CRLF line endings.
acknowledgements.txt text eol=crlf

# Binary files
*.ico binary
